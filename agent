#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
AGENTS_DIR=".agents"
AGENTS_MD="AGENTS.md"
HANDOVERS_DIR="$AGENTS_DIR/handovers"
HOOKS_DIR="$AGENTS_DIR/hooks"
CONFIG_FILE="$AGENTS_DIR/config.yaml"

# ── Colors ────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────

die() { echo -e "${RED}error:${RESET} $1" >&2; exit 1; }
info() { echo -e "${BLUE}→${RESET} $1"; }
success() { echo -e "${GREEN}✓${RESET} $1"; }
warn() { echo -e "${YELLOW}!${RESET} $1"; }

require_git() {
  git rev-parse --git-dir &>/dev/null || die "not a git repository. Run 'git init' first."
}

require_init() {
  [ -d "$AGENTS_DIR" ] || die "agent not initialized. Run 'agent init' first."
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

timestamp() {
  date -u +"%Y-%m-%dT%H-%M-%S"
}

iso_date() {
  date -u +"%Y-%m-%d %H:%M UTC"
}

find_editor() {
  if [ -n "${VISUAL:-}" ]; then
    printf '%s\n' "$VISUAL"
    return 0
  fi

  if [ -n "${EDITOR:-}" ]; then
    printf '%s\n' "$EDITOR"
    return 0
  fi

  local editor
  for editor in nano vim vi; do
    if command -v "$editor" >/dev/null 2>&1; then
      printf '%s\n' "$editor"
      return 0
    fi
  done

  return 1
}

# ── MCP Integration (via mcp2cli) ────────────────────────

has_mcp2cli() {
  command -v mcp2cli &>/dev/null
}

run_mcp2cli() {
  if has_mcp2cli; then
    mcp2cli "$@"
  elif command -v uvx &>/dev/null; then
    uvx mcp2cli "$@"
  else
    die "mcp2cli not found. Install with: pip install mcp2cli  (or: uvx mcp2cli --help)"
  fi
}

# ── CMUX Integration ─────────────────────────────────────

has_cmux() {
  command -v cmux &>/dev/null
}

cmux_set_status() {
  has_cmux && cmux set-status "$@" 2>/dev/null || true
}

cmux_clear_status() {
  has_cmux && cmux clear-status "$@" 2>/dev/null || true
}

cmux_log() {
  # Usage: cmux_log <level> <source> <message>
  has_cmux && cmux log --level "$1" --source "$2" -- "$3" 2>/dev/null || true
}

cmux_progress() {
  # Usage: cmux_progress <0.0-1.0> <label>
  has_cmux && cmux set-progress "$1" --label "$2" 2>/dev/null || true
}

cmux_clear_progress() {
  has_cmux && cmux clear-progress 2>/dev/null || true
}

cmux_notify() {
  # Usage: cmux_notify <title> <body>
  has_cmux && cmux notify --title "$1" --body "$2" 2>/dev/null || true
}

cmux_rename_workspace() {
  has_cmux && cmux rename-workspace "$1" 2>/dev/null || true
}

# ── Playwright CLI Integration ────────────────────────────

PLAYWRIGHT_CONFIG=".playwright/cli.config.json"
PLAYWRIGHT_SKILLS_DIR=".claude/skills/playwright-cli"

has_playwright_cli() { command -v playwright-cli &>/dev/null; }
playwright_cli_version() { has_playwright_cli && playwright-cli --version 2>/dev/null || echo "not installed"; }
playwright_cli_has_skills() { [ -f "$PLAYWRIGHT_SKILLS_DIR/SKILL.md" ]; }

# ── Workflow Recommendations ──────────────────────────────

RECOMMENDATIONS_FILE="$AGENTS_DIR/recommendations.md"

_detect_project_issues() {
  local root
  root=$(repo_root 2>/dev/null || pwd)
  local issues=""

  # No .gitignore
  [ ! -f "$root/.gitignore" ] && issues+="[hygiene] Add a .gitignore file"$'\n'

  # No test directory
  if [ ! -d "$root/test" ] && [ ! -d "$root/tests" ] && [ ! -d "$root/__tests__" ] && [ ! -d "$root/spec" ]; then
    issues+="[testing] Add tests — no test directory found (test/, tests/, __tests__/, spec/)"$'\n'
  fi

  # No CI config
  if [ ! -d "$root/.github/workflows" ] && [ ! -f "$root/.gitlab-ci.yml" ] && [ ! -f "$root/Jenkinsfile" ] && [ ! -f "$root/.circleci/config.yml" ]; then
    issues+="[hygiene] Add CI/CD — no workflow config found"$'\n'
  fi

  # .env exists but no .env.example
  if [ -f "$root/.env" ] && [ ! -f "$root/.env.example" ]; then
    issues+="[security] Add .env.example for team onboarding — .env exists without a template"$'\n'
  fi

  # No lockfile but package manager config exists
  if [ -f "$root/package.json" ] && [ ! -f "$root/package-lock.json" ] && [ ! -f "$root/yarn.lock" ] && [ ! -f "$root/pnpm-lock.yaml" ] && [ ! -f "$root/bun.lockb" ]; then
    issues+="[hygiene] Commit lockfile — package.json found without a lockfile"$'\n'
  fi
  if [ -f "$root/Gemfile" ] && [ ! -f "$root/Gemfile.lock" ]; then
    issues+="[hygiene] Commit Gemfile.lock"$'\n'
  fi
  if [ -f "$root/go.mod" ] && [ ! -f "$root/go.sum" ]; then
    issues+="[hygiene] Commit go.sum"$'\n'
  fi

  # node_modules not in .gitignore
  if [ -f "$root/package.json" ] && [ -f "$root/.gitignore" ]; then
    if ! grep -q "node_modules" "$root/.gitignore" 2>/dev/null; then
      issues+="[security] Add node_modules/ to .gitignore"$'\n'
    fi
  fi

  # No README
  if [ ! -f "$root/README.md" ] && [ ! -f "$root/readme.md" ] && [ ! -f "$root/README" ]; then
    issues+="[docs] Add a README"$'\n'
  fi

  # AGENTS.md has _TODO: placeholders
  if [ -f "$root/$AGENTS_MD" ] && grep -q "_TODO:" "$root/$AGENTS_MD" 2>/dev/null; then
    issues+="[docs] Fill in AGENTS.md sections — _TODO: placeholders remain"$'\n'
  fi

  # Playwright CLI not installed
  if ! has_playwright_cli; then
    issues+="[tooling] Run \`agent setup\` to install Playwright CLI"$'\n'
  fi

  # CMUX not installed
  if ! has_cmux; then
    issues+="[tooling] Install CMUX for workspace management — https://cmux.dev"$'\n'
  fi

  printf '%s' "$issues"
}

build_handover_summary_draft() {
  local branch="$1"
  local staged_count unstaged_count untracked_count total_count

  staged_count=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
  unstaged_count=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
  untracked_count=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
  total_count=$((staged_count + unstaged_count + untracked_count))

  if [ "$total_count" -gt 0 ] 2>/dev/null; then
    printf 'Updated %s file(s) on %s.' "$total_count" "$branch"
    return 0
  fi

  printf 'Wrapped up work on %s.' "$branch"
}

review_handover_draft() {
  local branch="$1"
  local last_commits="$2"
  local staged="$3"
  local unstaged="$4"
  local draft_summary="$5"
  local draft_decisions="$6"
  local draft_learnings="$7"
  local draft_next_steps="$8"
  local choice editor draft_file input

  while true; do
    echo -e "${BOLD}Agent Handover${RESET} — $(iso_date)"
    echo ""
    echo -e "${DIM}Review the draft below. Edit it if needed, then accept to write the handover.${RESET}"
    echo ""
    echo -e "${BOLD}Draft Summary:${RESET} $draft_summary"
    echo -e "${BOLD}Draft Decisions:${RESET} $draft_decisions"
    echo -e "${BOLD}Draft Learnings / Gotchas:${RESET} $draft_learnings"
    echo -e "${BOLD}Draft Next Steps:${RESET} $draft_next_steps"
    echo ""
    echo -e "${DIM}Branch:${RESET} $branch"
    echo -e "${DIM}Recent commits:${RESET}"
    printf '%s\n' "$last_commits"
    echo ""
    echo -e "${DIM}Staged changes:${RESET}"
    printf '%s\n' "$staged"
    echo ""
    echo -e "${DIM}Unstaged changes:${RESET}"
    printf '%s\n' "$unstaged"
    echo ""
    printf 'Accept draft, edit draft, or cancel? [a/e/c]: '
    read -r choice

    case "$choice" in
      a|A|"")
        HANDOVER_SUMMARY="$draft_summary"
        HANDOVER_DECISIONS="$draft_decisions"
        HANDOVER_LEARNINGS="$draft_learnings"
        HANDOVER_NEXT_STEPS="$draft_next_steps"
        return 0
        ;;
      e|E)
        if editor=$(find_editor); then
          draft_file=$(mktemp)
          cat > "$draft_file" << EOF
Summary: $draft_summary
Decisions: $draft_decisions
Learnings: $draft_learnings
Next Steps: $draft_next_steps
EOF
          "$editor" "$draft_file"
          while IFS= read -r input; do
            case "$input" in
              Summary:*) draft_summary=${input#Summary: } ;;
              Decisions:*) draft_decisions=${input#Decisions: } ;;
              Learnings:*) draft_learnings=${input#Learnings: } ;;
              Next\ Steps:*) draft_next_steps=${input#Next Steps: } ;;
            esac
          done < "$draft_file"
          rm -f "$draft_file"
        else
          printf 'Summary [%s]: ' "$draft_summary"
          read -r input
          [ -n "$input" ] && draft_summary="$input"
          printf 'Decisions [%s]: ' "$draft_decisions"
          read -r input
          [ -n "$input" ] && draft_decisions="$input"
          printf 'Learnings [%s]: ' "$draft_learnings"
          read -r input
          [ -n "$input" ] && draft_learnings="$input"
          printf 'Next Steps [%s]: ' "$draft_next_steps"
          read -r input
          [ -n "$input" ] && draft_next_steps="$input"
        fi
        echo ""
        ;;
      c|C)
        warn "handover cancelled"
        return 1
        ;;
      *)
        warn "enter 'a' to accept, 'e' to edit, or 'c' to cancel"
        echo ""
        ;;
    esac
  done
}

# ── Commands ──────────────────────────────────────────────

cmd_init() {
  require_git
  local force=false
  if [ "${1:-}" = "--force" ] || [ "${1:-}" = "-f" ]; then
    force=true
    shift
  fi

  local root
  root=$(repo_root)
  cd "$root"

  if [ -d "$AGENTS_DIR" ] && [ "$force" = false ]; then
    warn "already initialized at $root/$AGENTS_DIR"
    echo "  Run 'agent reinit' to regenerate config files, or 'agent init --force' to start fresh."
    return 0
  fi

  local project_name
  project_name=$(basename "$root")

  info "Initializing agent handoff system in ${BOLD}$root${RESET}"

  # Create directory structure
  mkdir -p "$HANDOVERS_DIR" "$HOOKS_DIR"

  # Create config
  cat > "$CONFIG_FILE" << EOF
# Agent handoff configuration
project: $project_name
created: $(iso_date)

# Conventions for agents working on this repo
conventions:
  language: auto        # auto-detect from repo
  test_before_commit: true
  update_handover: true # remind agents to write handover before committing

# Agent-specific config file pointers (all point to AGENTS.md)
# These are auto-generated — edit AGENTS.md, not these files
agent_files:
  # IDE agents
  - .cursorrules              # Cursor
  - .windsurfrules            # Windsurf
  - .clinerules               # Cline
  - .github/copilot-instructions.md  # GitHub Copilot
  # Terminal agents
  - CLAUDE.md                 # Claude Code
  - .cosine/instructions.md   # Cosine (cos2)
  - .opencode/instructions.md # OpenCode
  - .codex/instructions.md    # Codex
  - .aider.conf.yml           # Aider
  # Generic
  - CONVENTIONS.md
EOF

  # Create AGENTS.md from template (skip if user has existing content)
  local agents_md_kept=false
  if [ "$force" = true ]; then
    _generate_agents_md "$project_name"
  elif [ -f "$AGENTS_MD" ] && [ -s "$AGENTS_MD" ] && \
       ! grep -q '_TODO: Add project overview_' "$AGENTS_MD" 2>/dev/null; then
    # Non-empty and not the unedited template — preserve it
    agents_md_kept=true
    info "Existing ${BOLD}AGENTS.md${RESET} found — keeping it."
  else
    _generate_agents_md "$project_name"
  fi

  # Create agent config pointers
  if [ "$force" = true ]; then
    # Bypass merge logic — overwrite everything
    local pointer
    pointer=$(_agent_pointer_content)
    for f in .cursorrules .windsurfrules .clinerules CLAUDE.md .aider.conf.yml CONVENTIONS.md; do
      echo "$pointer" > "$f"
    done
    for d in .github .cosine .opencode .codex; do
      mkdir -p "$d"
    done
    echo "$pointer" > .github/copilot-instructions.md
    echo "$pointer" > .cosine/instructions.md
    echo "$pointer" > .opencode/instructions.md
    echo "$pointer" > .codex/instructions.md
  else
    _create_agent_pointers
  fi

  # Install git hooks
  _install_hooks

  # ── Tool detection ──
  local tools_detected=""

  if has_playwright_cli; then
    info "Detected playwright-cli — installing skills..."
    playwright-cli install --skills 2>/dev/null && {
      success "Playwright CLI skills installed"
      tools_detected+="playwright "
    } || warn "failed to install Playwright CLI skills (non-fatal)"
  else
    echo -e "  ${DIM}Playwright CLI not found. Install with:${RESET} agent test install ${DIM}or${RESET} agent setup"
  fi

  if has_cmux; then
    tools_detected+="cmux "
    success "CMUX detected"
  else
    echo -e "  ${DIM}CMUX not found. Install from:${RESET} https://cmux.dev"
  fi

  # Create .gitignore additions
  if [ -f .gitignore ]; then
    if ! grep -q ".agents/handovers/" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "# Agent handoff context dumps (can be large)" >> .gitignore
      echo "# Uncomment the next line to exclude handover logs from git" >> .gitignore
      echo "# .agents/handovers/" >> .gitignore
    fi
  fi

  echo ""
  success "Agent handoff system initialized"
  echo ""
  echo -e "  ${BOLD}What was created:${RESET}"
  if [ "$agents_md_kept" = true ]; then
    echo -e "  ${DIM}AGENTS.md${RESET}              ← kept existing (source of truth)"
  else
    echo -e "  ${DIM}AGENTS.md${RESET}              ← the source of truth (edit this)"
  fi
  echo -e "  ${DIM}.agents/${RESET}               ← handovers, config, hooks"
  echo ""
  echo -e "  ${BOLD}Agent pointers (all → AGENTS.md):${RESET}"
  echo -e "  ${DIM}.cursorrules${RESET}            Cursor"
  echo -e "  ${DIM}.windsurfrules${RESET}          Windsurf"
  echo -e "  ${DIM}.clinerules${RESET}             Cline"
  echo -e "  ${DIM}.github/copilot-*.md${RESET}    GitHub Copilot"
  echo -e "  ${DIM}CLAUDE.md${RESET}               Claude Code"
  echo -e "  ${DIM}.cosine/instructions${RESET}    Cosine (cos2)"
  echo -e "  ${DIM}.opencode/instructions${RESET}  OpenCode"
  echo -e "  ${DIM}.codex/instructions${RESET}     Codex"
  echo -e "  ${DIM}.aider.conf.yml${RESET}         Aider"

  if echo "$tools_detected" | grep -q "playwright"; then
    echo ""
    echo -e "  ${BOLD}Skills:${RESET}"
    echo -e "  ${DIM}$PLAYWRIGHT_SKILLS_DIR${RESET}  Playwright CLI"
  fi

  echo ""
  echo -e "  ${BOLD}Next steps:${RESET}"
  echo -e "  1. Edit ${BOLD}AGENTS.md${RESET} with your project context"
  echo -e "  2. Start working with ${BOLD}any${RESET} agent tool — they all read AGENTS.md"
  echo -e "  3. Run ${BOLD}agent handover${RESET} before switching to a different agent"

  # ── CMUX workspace setup ──
  if has_cmux; then
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "main")
    cmux_rename_workspace "$project_name"
    cmux_set_status "project" "$project_name" --icon "folder.fill" --color "#64B5F6"
    cmux_set_status "branch" "$branch" --icon "arrow.triangle.branch" --color "#81C784"
    cmux_set_status "agent" "ready" --icon "bolt.fill" --color "#FFD54F"
    cmux_set_status "handovers" "0" --icon "doc.text.fill" --color "#B0BEC5"
    cmux_log "success" "agent" "Initialized agent handoff for $project_name"
    echo ""
    success "CMUX workspace configured"
  fi
}

cmd_handover() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local ts
  ts=$(timestamp)
  local handover_file="$HANDOVERS_DIR/$ts.md"

  # Gather context
  local branch
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local last_commits
  last_commits=$(git log --oneline -5 2>/dev/null || echo "no commits yet")
  local staged
  staged=$(git diff --cached --stat 2>/dev/null || echo "nothing staged")
  local unstaged
  unstaged=$(git diff --stat 2>/dev/null || echo "nothing unstaged")
  local untracked
  untracked=$(git ls-files --others --exclude-standard 2>/dev/null)

  if [ -n "$untracked" ]; then
    unstaged=$(printf '%s\n\nUntracked files:\n%s' "$unstaged" "$untracked")
  fi

  # Signal handover in progress
  cmux_set_status "agent" "handing over..." --icon "arrow.triangle.2.circlepath" --color "#FFB74D"
  cmux_progress 0.5 "Writing handover..."

  # Check for arguments (non-interactive mode for agents)
  local summary=""
  local decisions=""
  local learnings=""
  local next_steps=""
  local context=""
  local summary_draft=""
  local recommend=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --summary|-s) summary="$2"; shift 2 ;;
      --decisions|-d) decisions="$2"; shift 2 ;;
      --learnings|-l) learnings="$2"; shift 2 ;;
      --next|-n) next_steps="$2"; shift 2 ;;
      --context|-c) context="$2"; shift 2 ;;
      --recommend|-r) recommend="$2"; shift 2 ;;
      --stdin) context=$(cat); shift ;;
      *) die "unknown option: $1" ;;
    esac
  done

  # If no args, check if stdin has data (piped context)
  if [ -z "$summary" ] && [ -z "$context" ] && [ ! -t 0 ]; then
    context=$(cat)
    summary="Automated handover"
  fi

  # If still no args and interactive terminal, prompt
  if [ -z "$summary" ] && [ -t 0 ]; then
    summary_draft=$(build_handover_summary_draft "$branch")
    decisions="_No decisions logged._"
    learnings="_No learnings or gotchas logged._"
    next_steps="_No next steps logged._"

    review_handover_draft "$branch" "$last_commits" "$staged" "$unstaged" "$summary_draft" "$decisions" "$learnings" "$next_steps" || return 1
    summary="$HANDOVER_SUMMARY"
    decisions="$HANDOVER_DECISIONS"
    learnings="$HANDOVER_LEARNINGS"
    next_steps="$HANDOVER_NEXT_STEPS"
  fi

  [ -z "$summary" ] && summary="Work session $(iso_date)"

  # Write handover file
  cat > "$handover_file" << EOF
# Handover — $(iso_date)

## Summary
$summary

## Key Decisions
${decisions:-_No decisions logged._}

## Learnings / Gotchas
${learnings:-_No learnings or gotchas logged._}

## Next Steps
${next_steps:-_No next steps logged._}

## Git State
- **Branch:** $branch
- **Recent commits:**
\`\`\`
$last_commits
\`\`\`
- **Staged changes:**
\`\`\`
$staged
\`\`\`
- **Unstaged changes:**
\`\`\`
$unstaged
\`\`\`
EOF

  # Append context dump if provided
  if [ -n "$context" ]; then
    cat >> "$handover_file" << EOF

## Conversation Context
<details>
<summary>Full context from agent session (click to expand)</summary>

$context

</details>
EOF
  fi

  # Append Workflow Recommendations section
  local auto_issues
  auto_issues=$(_detect_project_issues)
  if [ -n "$auto_issues" ] || [ -n "$recommend" ]; then
    cat >> "$handover_file" << 'RECSECTION'

## Workflow Recommendations
RECSECTION

    local date_str
    date_str=$(iso_date)

    # Auto-detected issues
    if [ -n "$auto_issues" ]; then
      while IFS= read -r rec_line; do
        [ -z "$rec_line" ] && continue
        echo "- **$date_str** [auto] $rec_line" >> "$handover_file"
      done <<< "$auto_issues"
    fi

    # Agent-provided recommendation
    if [ -n "$recommend" ]; then
      echo "- **$date_str** [agent] $recommend" >> "$handover_file"
    fi

    # Also append to recommendations log
    mkdir -p "$AGENTS_DIR"
    if [ ! -f "$RECOMMENDATIONS_FILE" ]; then
      echo "# Workflow Recommendations" > "$RECOMMENDATIONS_FILE"
      echo "" >> "$RECOMMENDATIONS_FILE"
    fi
    if [ -n "$auto_issues" ]; then
      while IFS= read -r rec_line; do
        [ -z "$rec_line" ] && continue
        echo "- **$date_str** [auto] $rec_line" >> "$RECOMMENDATIONS_FILE"
      done <<< "$auto_issues"
    fi
    if [ -n "$recommend" ]; then
      echo "- **$date_str** [agent] $recommend" >> "$RECOMMENDATIONS_FILE"
    fi
  fi

  # Update AGENTS.md with latest handover summary
  _update_agents_md_progress "$summary" "$learnings" "$next_steps"

  success "Handover saved to $handover_file"
  echo ""
  echo -e "  ${DIM}Summary:${RESET} $summary"
  if [ -n "$decisions" ] && [ "$decisions" != "_No decisions logged._" ]; then echo -e "  ${DIM}Decisions:${RESET} $decisions"; fi
  if [ -n "$learnings" ] && [ "$learnings" != "_No learnings or gotchas logged._" ]; then echo -e "  ${DIM}Learnings:${RESET} $learnings"; fi
  if [ -n "$next_steps" ] && [ "$next_steps" != "_No next steps logged._" ]; then echo -e "  ${DIM}Next steps:${RESET} $next_steps"; fi
  if [ -n "$context" ]; then echo -e "  ${DIM}Context:${RESET} $(echo "$context" | wc -c | tr -d ' ') bytes captured"; fi

  # ── CMUX handover complete ──
  local handover_count
  handover_count=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  cmux_set_status "agent" "handed over" --icon "checkmark.circle.fill" --color "#81C784"
  cmux_set_status "handovers" "$handover_count" --icon "doc.text.fill" --color "#B0BEC5"
  cmux_set_status "last-handover" "$(iso_date)" --icon "clock.fill" --color "#90A4AE"
  cmux_progress 1.0 "Handover complete"
  cmux_log "success" "agent" "Handover: $summary"
  cmux_notify "Agent Handover Complete" "$summary"
}

cmd_status() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local project_name
  project_name=$(basename "$root")

  echo -e "${BOLD}Agent Status — $project_name${RESET}"
  echo ""

  # Last handover
  local latest
  latest=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | sort -r | head -1)
  if [ -n "$latest" ]; then
    local handover_name
    handover_name=$(basename "$latest" .md)
    local handover_summary
    handover_summary=$(sed -n '/^## Summary$/,/^##/{/^## Summary$/d;/^##/d;p;}' "$latest" | head -3 | sed 's/^[[:space:]]*//')
    echo -e "  ${BOLD}Last handover:${RESET} $handover_name"
    echo -e "  ${DIM}$handover_summary${RESET}"
  else
    echo -e "  ${BOLD}Last handover:${RESET} ${DIM}none${RESET}"
  fi
  echo ""

  # Handover count
  local count
  count=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  ${BOLD}Total handovers:${RESET} $count"

  # Git state
  local branch
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local uncommitted
  uncommitted=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  ${BOLD}Branch:${RESET} $branch"
  echo -e "  ${BOLD}Uncommitted changes:${RESET} $uncommitted files"

  # AGENTS.md exists and has content
  if [ -f "$AGENTS_MD" ]; then
    local lines
    lines=$(wc -l < "$AGENTS_MD" | tr -d ' ')
    echo -e "  ${BOLD}AGENTS.md:${RESET} $lines lines"
  else
    echo -e "  ${BOLD}AGENTS.md:${RESET} ${RED}missing${RESET}"
  fi

  # CMUX sidebar sync
  if has_cmux; then
    echo -e "  ${BOLD}CMUX:${RESET} ${GREEN}connected${RESET}"
    cmux_set_status "project" "$project_name" --icon "folder.fill" --color "#64B5F6"
    cmux_set_status "branch" "$branch" --icon "arrow.triangle.branch" --color "#81C784"
    cmux_set_status "handovers" "$count" --icon "doc.text.fill" --color "#B0BEC5"
    cmux_set_status "uncommitted" "$uncommitted files" --icon "pencil.circle.fill" --color "#FFB74D"
    cmux_rename_workspace "$project_name"
  else
    echo -e "  ${BOLD}CMUX:${RESET} ${DIM}not available${RESET}"
  fi
  echo ""
}

cmd_log() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local handovers
  handovers=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | sort -r)

  if [ -z "$handovers" ]; then
    echo -e "${DIM}No handovers yet. Run 'agent handover' to create one.${RESET}"
    return 0
  fi

  echo -e "${BOLD}Handover Log${RESET}"
  echo ""

  local limit=${1:-10}
  local i=0

  for file in $handovers; do
    [ $i -ge "$limit" ] && break
    local name
    name=$(basename "$file" .md)
    local summary
    summary=$(sed -n '/^## Summary$/,/^##/{/^## Summary$/d;/^##/d;p;}' "$file" | head -1 | sed 's/^[[:space:]]*//')
    echo -e "  ${YELLOW}$name${RESET}  $summary"
    i=$((i + 1))
  done

  local total
  total=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$total" -gt "$limit" ] 2>/dev/null; then
    echo -e "\n  ${DIM}... and $((total - limit)) more${RESET}"
  fi
}

cmd_onboard() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local name="${1:-}"
  local config_path="${2:-}"

  if [ -z "$name" ]; then
    echo -e "${BOLD}Onboard a new agent tool${RESET}"
    echo ""
    echo -e "${DIM}Agent tool name (e.g. 'devin', 'bolt', 'replit-agent'):${RESET}"
    read -r name
    [ -z "$name" ] && die "agent name is required"
    echo ""
    echo -e "${DIM}Config file path this agent reads (e.g. '.devin/instructions.md', 'DEVIN.md'):${RESET}"
    echo -e "${DIM}Leave empty to create ${name}.md in the repo root${RESET}"
    read -r config_path
  fi

  # Default config path: {name}.md in repo root, or .{name}/instructions.md if name is lowercase
  if [ -z "$config_path" ]; then
    local lower
    lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
    config_path=".${lower}/instructions.md"
  fi

  # Create the pointer file (merge with existing content if present)
  local dir
  dir=$(dirname "$config_path")
  if [ "$dir" != "." ]; then
    mkdir -p "$dir"
  fi
  _write_pointer_file "$config_path"

  # Register in config
  echo "  - $config_path    # $name" >> "$CONFIG_FILE"

  success "Onboarded ${BOLD}$name${RESET}"
  echo ""
  echo -e "  ${DIM}Created:${RESET} $config_path → points to AGENTS.md"
  echo -e "  ${DIM}Registered in:${RESET} $CONFIG_FILE"
  echo ""
  echo -e "  $name will now read AGENTS.md when it opens this repo."
}

cmd_reinit() {
  require_git
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  info "Regenerating agent config files (AGENTS.md untouched)"
  _create_agent_pointers
  _install_hooks
  success "Agent config files regenerated"
}

cmd_workspace() {
  local subcmd="${1:-sync}"
  shift 2>/dev/null || true

  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for workspace management."
  fi

  case "$subcmd" in
    name|rename)
      local name="${1:-}"
      if [ -z "$name" ]; then
        require_git
        name=$(basename "$(repo_root)")
      fi
      cmux_rename_workspace "$name"
      success "Workspace renamed to: $name"
      ;;
    sync)
      require_git
      require_init
      local root
      root=$(repo_root)
      cd "$root"

      local project_name branch count uncommitted
      project_name=$(basename "$root")
      branch=$(git branch --show-current 2>/dev/null || echo "unknown")
      count=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
      uncommitted=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')

      cmux_rename_workspace "$project_name"
      cmux_set_status "project" "$project_name" --icon "folder.fill" --color "#64B5F6"
      cmux_set_status "branch" "$branch" --icon "arrow.triangle.branch" --color "#81C784"
      cmux_set_status "handovers" "$count" --icon "doc.text.fill" --color "#B0BEC5"
      cmux_set_status "uncommitted" "$uncommitted files" --icon "pencil.circle.fill" --color "#FFB74D"
      cmux_set_status "agent" "active" --icon "bolt.fill" --color "#FFD54F"
      cmux_log "info" "agent" "Workspace synced for $project_name ($branch)"
      success "CMUX workspace synced"
      ;;
    *)
      die "unknown workspace command: $subcmd. Use 'name <title>' or 'sync'."
      ;;
  esac
}

cmd_peek() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for peek."
  fi

  local target="${1:-}"

  if [ -z "$target" ]; then
    # List available workspaces
    echo -e "${BOLD}Workspaces${RESET}"
    echo ""
    cmux list-workspaces
    echo ""
    echo -e "${DIM}Usage: agent peek <workspace-ref>  (e.g. agent peek workspace:3)${RESET}"
    return 0
  fi

  echo -e "${BOLD}Screen — $target${RESET}"
  echo ""
  cmux read-screen --workspace "$target" 2>/dev/null || die "could not read workspace: $target"
}

cmd_dashboard() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for dashboard."
  fi

  echo -e "${BOLD}Agent Dashboard${RESET}"
  echo ""

  local workspaces
  workspaces=$(cmux list-workspaces 2>/dev/null)

  echo "$workspaces" | while IFS= read -r line; do
    # Extract workspace ref (first word after optional *)
    local ref
    ref=$(echo "$line" | sed 's/^\* *//' | awk '{print $1}')
    local name
    name=$(echo "$line" | sed 's/^[* ]*//' | sed "s/^$ref[[:space:]]*//" | sed 's/\[selected\]//')
    local selected=""
    if echo "$line" | grep -q '\[selected\]'; then
      selected=" ${GREEN}◀${RESET}"
    fi

    # Get sidebar state for this workspace
    local state
    state=$(cmux sidebar-state --workspace "$ref" 2>/dev/null || echo "")
    local branch
    branch=$(echo "$state" | grep "^git_branch=" | cut -d= -f2)
    local cwd
    cwd=$(echo "$state" | grep "^cwd=" | cut -d= -f2)
    cwd=$(basename "$cwd" 2>/dev/null || echo "$cwd")

    echo -e "  ${YELLOW}$ref${RESET}  ${BOLD}$cwd${RESET}${selected}"
    if [ -n "$branch" ] && [ "$branch" != "none" ]; then
      echo -e "         ${DIM}branch:${RESET} $branch"
    fi
    if [ -n "$name" ] && [ "$name" != "$cwd" ]; then
      echo -e "         ${DIM}title:${RESET} $(echo "$name" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')"
    fi
    echo ""
  done
}

cmd_spawn() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for spawn."
  fi

  local task_desc="${1:-}"
  if [ -z "$task_desc" ]; then
    die "usage: agent spawn \"task description\" [--command <shell-cmd>]"
  fi

  local shell_cmd=""
  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --command|-c) shell_cmd="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  # Create new workspace
  local result
  if [ -n "$shell_cmd" ]; then
    result=$(cmux new-workspace --command "$shell_cmd" 2>&1)
  else
    result=$(cmux new-workspace 2>&1)
  fi

  if ! echo "$result" | grep -q "^OK"; then
    die "failed to create workspace: $result"
  fi

  # Extract UUID from "OK <uuid>" response — use it directly as workspace ID
  local ws_ref
  ws_ref=$(echo "$result" | sed 's/^OK[[:space:]]*//')

  # Name it with the task description (truncated)
  local short_name
  short_name=$(echo "$task_desc" | cut -c1-40)
  cmux rename-workspace --workspace "$ws_ref" "$short_name" 2>/dev/null || true

  # Set status pills on the new workspace
  cmux set-status "task" "$task_desc" --icon "hammer.fill" --color "#FFB74D" --workspace "$ws_ref" 2>/dev/null || true
  cmux set-status "agent" "spawned" --icon "sparkle" --color "#CE93D8" --workspace "$ws_ref" 2>/dev/null || true
  cmux log --level info --source "agent" --workspace "$ws_ref" -- "Spawned for: $task_desc" 2>/dev/null || true

  # If we're in an agent-initialized repo, cd there and show the task
  local root
  root=$(repo_root 2>/dev/null || echo "")
  if [ -n "$root" ] && [ -d "$root/$AGENTS_DIR" ]; then
    cmux send --workspace "$ws_ref" "cd $root" 2>/dev/null || true
    cmux send-key --workspace "$ws_ref" Enter 2>/dev/null || true
  fi

  success "Spawned workspace ${BOLD}$ws_ref${RESET} — $task_desc"
  echo ""
  echo -e "  ${DIM}Switch to it:${RESET} cmux select-workspace --workspace $ws_ref"
}

cmd_signal() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for signal."
  fi

  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    send)
      local name="${1:-}"
      [ -z "$name" ] && die "usage: agent signal send <name>"
      cmux wait-for --signal "$name" 2>/dev/null
      cmux_log "info" "agent" "Signal sent: $name"
      cmux_notify "Agent Signal" "Signal '$name' sent"
      success "Signal sent: $name"
      ;;
    wait)
      local name="${1:-}"
      [ -z "$name" ] && die "usage: agent signal wait <name> [--timeout <seconds>]"
      shift
      local timeout_args=""
      if [ "${1:-}" = "--timeout" ] && [ -n "${2:-}" ]; then
        timeout_args="--timeout $2"
      fi
      info "Waiting for signal: $name..."
      cmux_set_status "agent" "waiting: $name" --icon "hourglass" --color "#90A4AE"
      # shellcheck disable=SC2086
      cmux wait-for "$name" $timeout_args 2>/dev/null
      local exit_code=$?
      if [ $exit_code -eq 0 ]; then
        cmux_set_status "agent" "active" --icon "bolt.fill" --color "#FFD54F"
        success "Signal received: $name"
      else
        cmux_set_status "agent" "timeout" --icon "exclamationmark.triangle.fill" --color "#EF5350"
        die "timed out waiting for signal: $name"
      fi
      ;;
    *)
      die "usage: agent signal <send|wait> <name> [--timeout <seconds>]"
      ;;
  esac
}

cmd_browse() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for browse."
  fi

  local url="${1:-}"
  local snapshot="${2:-}"

  if [ -z "$url" ]; then
    die "usage: agent browse <url> [--snapshot]"
  fi

  info "Opening browser: $url"
  local result
  result=$(cmux browser open "$url" 2>&1)

  if echo "$result" | grep -q "OK"; then
    local surface
    surface=$(echo "$result" | grep -o 'surface=surface:[0-9]*' | cut -d= -f2)
    cmux_log "info" "agent" "Opened browser: $url"
    success "Browser opened in $surface"

    if [ "$snapshot" = "--snapshot" ] || [ "$snapshot" = "-s" ]; then
      # Wait for page to load
      cmux browser wait --load-state complete --surface "$surface" 2>/dev/null || true
      echo ""
      cmux browser snapshot --surface "$surface" 2>/dev/null || true
    fi
  else
    die "failed to open browser: $result"
  fi
}

cmd_context() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for context."
  fi

  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    push)
      local root
      root=$(repo_root 2>/dev/null || pwd)
      local project_name
      project_name=$(basename "$root")
      local branch
      branch=$(git branch --show-current 2>/dev/null || echo "unknown")

      # Build context payload
      local context=""
      context+="# Agent Context — $project_name"$'\n'
      context+="Branch: $branch"$'\n'
      context+="Time: $(iso_date)"$'\n'
      context+="CWD: $root"$'\n'
      context+=""$'\n'

      # Recent changes
      local diff_stat
      diff_stat=$(git diff --stat 2>/dev/null || echo "clean")
      context+="## Recent Changes"$'\n'
      context+="$diff_stat"$'\n'
      context+=""$'\n'

      # Last 5 commits
      local commits
      commits=$(git log --oneline -5 2>/dev/null || echo "no commits")
      context+="## Recent Commits"$'\n'
      context+="$commits"$'\n'
      context+=""$'\n'

      # Last handover summary if available
      if [ -d "$HANDOVERS_DIR" ]; then
        local latest=""
        latest=$(find "$HANDOVERS_DIR" -name "*.md" -type f 2>/dev/null | sort -r | head -1 || true)
        if [ -n "$latest" ]; then
          local summary
          summary=$(sed -n '/^## Summary$/,/^##/{/^## Summary$/d;/^##/d;p;}' "$latest" | head -3 | sed 's/^[[:space:]]*//')
          context+="## Last Handover"$'\n'
          context+="$summary"$'\n'
        fi
      fi

      local buffer_name="${1:-agent-context}"
      cmux set-buffer --name "$buffer_name" "$context" 2>/dev/null
      cmux_log "info" "agent" "Context pushed to buffer: $buffer_name"
      success "Context pushed to buffer: ${BOLD}$buffer_name${RESET}"
      echo ""
      echo -e "  ${DIM}Pull from another workspace:${RESET} agent context pull $buffer_name"
      ;;
    pull)
      local buffer_name="${1:-agent-context}"
      echo -e "${BOLD}Context — $buffer_name${RESET}"
      echo ""
      # paste-buffer sends to a surface, we need to read it differently
      # Use list-buffers to check existence, then paste
      local buffers
      buffers=$(cmux list-buffers 2>/dev/null)
      if echo "$buffers" | grep -q "^$buffer_name"; then
        # Read the buffer by pasting to a temp approach - just show what we stored
        # Actually, we need to use display-message or a workaround
        # The cleanest way: push context also to a status entry
        cmux paste-buffer --name "$buffer_name" 2>/dev/null
        success "Context from '$buffer_name' pasted to current surface"
      else
        die "buffer '$buffer_name' not found. Available buffers:"$'\n'"$buffers"
      fi
      ;;
    list)
      echo -e "${BOLD}Available Context Buffers${RESET}"
      echo ""
      cmux list-buffers 2>/dev/null || echo -e "  ${DIM}No buffers${RESET}"
      ;;
    *)
      die "usage: agent context <push|pull|list> [buffer-name]"
      ;;
  esac
}

cmd_focus() {
  if ! has_cmux; then
    die "cmux is not installed. CMUX is required for focus."
  fi

  local subcmd="${1:-}"

  case "$subcmd" in
    stop|done|end)
      # Check if there's a focus file
      local focus_file="/tmp/.agent-focus-$$"
      # Use a workspace-scoped focus file
      local ws_id
      ws_id=$(cmux identify --json 2>/dev/null | grep -o '"workspace_ref" *: *"[^"]*"' | head -1 | sed 's/.*: *"//;s/"//')
      focus_file="/tmp/.agent-focus-${ws_id:-unknown}"

      if [ -f "$focus_file" ]; then
        local start_time task_name
        start_time=$(head -1 "$focus_file")
        task_name=$(tail -1 "$focus_file")
        local now
        now=$(date +%s)
        local elapsed=$(( now - start_time ))
        local mins=$(( elapsed / 60 ))

        cmux_set_status "focus" "$task_name (${mins}m)" --icon "checkmark.circle.fill" --color "#81C784"
        cmux_log "success" "agent" "Focus complete: $task_name (${mins}m)"
        cmux_notify "Focus Complete" "$task_name — ${mins} minutes"
        rm -f "$focus_file"

        # Clear focus after a moment
        cmux_clear_status "focus"
        success "Focus ended: ${BOLD}$task_name${RESET} (${mins}m)"
      else
        warn "no active focus session"
      fi
      ;;
    "")
      die "usage: agent focus \"task name\" | agent focus stop"
      ;;
    *)
      # Start focus mode
      local task_name="$subcmd"
      # Combine remaining args
      shift
      if [ $# -gt 0 ]; then
        task_name="$task_name $*"
      fi

      local ws_id
      ws_id=$(cmux identify --json 2>/dev/null | grep -o '"workspace_ref" *: *"[^"]*"' | head -1 | sed 's/.*: *"//;s/"//')
      local focus_file="/tmp/.agent-focus-${ws_id:-unknown}"

      # Store start time and task
      date +%s > "$focus_file"
      echo "$task_name" >> "$focus_file"

      cmux_set_status "focus" "$task_name" --icon "scope" --color "#FFD54F"
      cmux_set_status "agent" "focused" --icon "eye.fill" --color "#64B5F6"
      cmux_log "info" "agent" "Focus started: $task_name"

      success "Focus started: ${BOLD}$task_name${RESET}"
      echo -e "  ${DIM}End with:${RESET} agent focus stop"
      ;;
  esac
}

cmd_test() {
  local subcmd="${1:-}"

  if [ -z "$subcmd" ]; then
    die "usage: agent test <url> [--headed] [--parallel N] [--session <name>]
       agent test install"
  fi

  if [ "$subcmd" = "install" ]; then
    _test_install
    return $?
  fi

  # It's a URL — run test
  _test_run "$@"
}

_test_install() {
  info "Installing Playwright CLI"

  if ! command -v npm &>/dev/null; then
    die "npm is required to install Playwright CLI. Install Node.js first."
  fi

  echo ""
  info "Installing @playwright/cli globally..."
  npm install -g @playwright/cli@latest || die "failed to install @playwright/cli"
  success "Playwright CLI installed"

  echo ""
  info "Installing browsers..."
  playwright-cli install || die "failed to install browsers"
  success "Browsers installed"

  echo ""
  info "Installing Claude Code skills..."
  playwright-cli install --skills || warn "failed to install skills (non-fatal)"
  success "Playwright CLI setup complete"

  echo ""
  echo -e "  ${BOLD}Installed:${RESET}"
  echo -e "  ${DIM}playwright-cli${RESET}  $(playwright_cli_version)"
  echo -e "  ${DIM}browsers${RESET}        chromium, firefox, webkit"
  if playwright_cli_has_skills; then
    echo -e "  ${DIM}skills${RESET}          $PLAYWRIGHT_SKILLS_DIR"
  fi
  echo ""
  echo -e "  ${BOLD}Try it:${RESET} agent test https://example.com --headed"
}

_test_run() {
  if ! has_playwright_cli; then
    die "playwright-cli is not installed. Run 'agent test install' first."
  fi

  local url="$1"
  shift

  local headed=false
  local parallel=0
  local session=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --headed)    headed=true; shift ;;
      --parallel)  parallel="$2"; shift 2 ;;
      --session|-s) session="$2"; shift 2 ;;
      *) die "unknown option: $1" ;;
    esac
  done

  if [ "$parallel" -gt 0 ] 2>/dev/null; then
    _test_run_parallel "$url" "$parallel" "$headed"
  else
    _test_run_single "$url" "$headed" "$session"
  fi
}

_test_run_single() {
  local url="$1"
  local headed="$2"
  local session="$3"

  local args=()
  args+=("open" "$url")

  if [ "$headed" = "true" ]; then
    args+=("--headed")
  fi

  if [ -n "$session" ]; then
    args+=("-s=$session")
  fi

  info "Opening Playwright session: $url"
  cmux_set_status "test" "testing: $url" --icon "globe" --color "#64B5F6"
  cmux_log "info" "agent" "Playwright test: $url"

  playwright-cli "${args[@]}"
}

_test_run_parallel() {
  local url="$1"
  local count="$2"
  local headed="$3"

  if ! has_cmux; then
    die "cmux is required for parallel test sessions. Install CMUX first."
  fi

  info "Spawning $count parallel test sessions for $url"
  echo ""

  local i
  for i in $(seq 1 "$count"); do
    local session_name="test-$i"
    local cmd="playwright-cli open $url -s=$session_name"
    if [ "$headed" = "true" ]; then
      cmd="$cmd --headed"
    fi

    local result
    result=$(cmux new-workspace --command "$cmd" 2>&1)

    if echo "$result" | grep -q "^OK"; then
      local ws_ref
      ws_ref=$(echo "$result" | sed 's/^OK[[:space:]]*//')
      cmux rename-workspace --workspace "$ws_ref" "test-$i" 2>/dev/null || true
      cmux set-status "test" "$session_name: $url" --icon "globe" --color "#64B5F6" --workspace "$ws_ref" 2>/dev/null || true
      success "Session $session_name → workspace $ws_ref"
    else
      warn "Failed to spawn session $session_name: $result"
    fi
  done

  echo ""
  success "Spawned $count parallel test sessions"
  echo -e "  ${DIM}View all:${RESET} agent dashboard"
}

cmd_setup() {
  echo -e "${BOLD}Agent Global Tool Setup${RESET}"
  echo ""

  # Check npm
  if command -v npm &>/dev/null; then
    local npm_ver
    npm_ver=$(npm --version 2>/dev/null)
    success "npm $npm_ver"
  else
    warn "npm not found — needed to install global tools"
    echo -e "  ${DIM}Install Node.js: https://nodejs.org${RESET}"
    echo ""
  fi

  # Check cmux
  if has_cmux; then
    success "cmux $(cmux --version 2>/dev/null || echo "installed")"
  else
    warn "cmux not found — needed for workspace management and parallel sessions"
    echo -e "  ${DIM}Install CMUX: https://cmux.dev${RESET}"
  fi

  # Check playwright-cli
  if has_playwright_cli; then
    success "playwright-cli $(playwright_cli_version)"
    if playwright_cli_has_skills; then
      success "playwright-cli skills installed"
    else
      echo ""
      echo -e "  ${DIM}Skills not installed. Install with:${RESET} playwright-cli install --skills"
    fi
  else
    warn "playwright-cli not found — needed for browser testing"
    if command -v npm &>/dev/null; then
      echo ""
      printf '  Install playwright-cli now? [y/N]: '
      read -r answer
      if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
        echo ""
        _test_install
      else
        echo -e "  ${DIM}Install later:${RESET} agent test install"
      fi
    else
      echo -e "  ${DIM}Install npm first, then:${RESET} agent test install"
    fi
  fi

  # Check mcp2cli
  if has_mcp2cli; then
    success "mcp2cli $(mcp2cli --version 2>/dev/null || echo "installed")"
  elif command -v uvx &>/dev/null; then
    success "mcp2cli available via uvx"
  else
    warn "mcp2cli not found — needed for agent mcp (MCP server bridge)"
    echo -e "  ${DIM}Install with: pip install mcp2cli  (or use uvx)${RESET}"
  fi

  echo ""
  echo -e "${BOLD}Tool Summary${RESET}"
  echo ""
  printf '  %-20s %s\n' "agent CLI" "$(command -v agent &>/dev/null && echo "${GREEN}available${RESET}" || echo "${YELLOW}current script${RESET}")"
  printf '  %-20s %s\n' "cmux" "$(has_cmux && echo -e "${GREEN}available${RESET}" || echo -e "${DIM}not installed${RESET}")"
  printf '  %-20s %s\n' "playwright-cli" "$(has_playwright_cli && echo -e "${GREEN}available${RESET}" || echo -e "${DIM}not installed${RESET}")"
  printf '  %-20s %s\n' "mcp2cli" "$(has_mcp2cli && echo -e "${GREEN}available${RESET}" || (command -v uvx &>/dev/null && echo -e "${GREEN}via uvx${RESET}" || echo -e "${DIM}not installed${RESET}"))"
  echo ""
}

cmd_recommend() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local suggestion=""
  local category="general"
  local auto_only=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auto)       auto_only=true; shift ;;
      --category|-c) category="$2"; shift 2 ;;
      *)            suggestion="$1"; shift ;;
    esac
  done

  # If a suggestion was provided, log it
  if [ -n "$suggestion" ]; then
    mkdir -p "$AGENTS_DIR"
    local date_str
    date_str=$(iso_date)
    if [ ! -f "$RECOMMENDATIONS_FILE" ]; then
      echo "# Workflow Recommendations" > "$RECOMMENDATIONS_FILE"
      echo "" >> "$RECOMMENDATIONS_FILE"
    fi
    echo "- **$date_str** [$category] $suggestion" >> "$RECOMMENDATIONS_FILE"
    success "Recommendation logged: [$category] $suggestion"
    return 0
  fi

  # Show recommendations
  echo -e "${BOLD}Workflow Recommendations${RESET}"
  echo ""

  # Auto-detected issues
  local auto_issues
  auto_issues=$(_detect_project_issues)

  if [ -n "$auto_issues" ]; then
    echo -e "  ${BOLD}Auto-detected issues:${RESET}"
    echo ""
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      echo -e "  ${YELLOW}!${RESET} $line"
    done <<< "$auto_issues"
    echo ""
  else
    echo -e "  ${GREEN}✓${RESET} No auto-detected issues"
    echo ""
  fi

  if [ "$auto_only" = true ]; then
    return 0
  fi

  # Logged recommendations
  if [ -f "$RECOMMENDATIONS_FILE" ]; then
    local logged
    logged=$(grep "^- " "$RECOMMENDATIONS_FILE" 2>/dev/null || true)
    if [ -n "$logged" ]; then
      echo -e "  ${BOLD}Logged recommendations:${RESET}"
      echo ""
      while IFS= read -r line; do
        [ -z "$line" ] && continue
        echo -e "  $line"
      done <<< "$logged"
      echo ""
    fi
  else
    echo -e "  ${DIM}No logged recommendations yet.${RESET}"
    echo -e "  ${DIM}Log one with: agent recommend \"your suggestion\"${RESET}"
    echo ""
  fi
}

