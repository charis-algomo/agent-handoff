case "${1:-help}" in
  init)       shift; cmd_init "$@" ;;
  handover)   shift; cmd_handover "$@" ;;
  status)     shift; cmd_status "$@" ;;
  log)        shift; cmd_log "$@" ;;
  onboard)    shift; cmd_onboard "$@" ;;
  reinit)     shift; cmd_reinit "$@" ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "agent $VERSION" ;;
  *) die "unknown command: $1. Run 'agent help' for usage." ;;
esac
