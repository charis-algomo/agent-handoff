_create_agent_pointers() {
  # Every AI coding agent reads a different config file.
  # We create ALL of them, each pointing to AGENTS.md as the single source of truth.
  # This means you can switch between any agent tool and they all get the same context.

  local pointer
  pointer=$(cat << 'POINTER'
# Agent Instructions

Read the `AGENTS.md` file in this repository root for all project context,
architecture decisions, conventions, progress history, and handoff notes.

That file is the single source of truth maintained across all agent sessions.
Always read it at the start of a new session. Update it when you make
significant decisions or complete major work.
POINTER
)

  # ── IDE agents ──────────────────────────────────────────
  # Cursor
  echo "$pointer" > .cursorrules

  # Windsurf
  echo "$pointer" > .windsurfrules

  # Cline (VS Code extension)
  echo "$pointer" > .clinerules

  # GitHub Copilot
  mkdir -p .github
  echo "$pointer" > .github/copilot-instructions.md

  # ── Terminal agents ─────────────────────────────────────
  # Claude Code
  echo "$pointer" > CLAUDE.md

  # Cosine (cos2)
  mkdir -p .cosine
  echo "$pointer" > .cosine/instructions.md

  # OpenCode
  mkdir -p .opencode
  echo "$pointer" > .opencode/instructions.md

  # Codex (OpenAI)
  mkdir -p .codex
  echo "$pointer" > .codex/instructions.md

  # Aider
  echo "$pointer" > .aider.conf.yml

  # ── Generic ─────────────────────────────────────────────
  # Some agents look for these
  echo "$pointer" > CONVENTIONS.md
}

_install_hooks() {
  local git_hooks_dir
  git_hooks_dir=$(git rev-parse --git-dir)/hooks

  # Pre-commit hook
  cat > "$git_hooks_dir/pre-commit" << 'HOOK'
#!/usr/bin/env bash
# Agent handoff pre-commit hook
# Reminds agents to create a handover entry before committing

AGENTS_DIR=".agents"
HANDOVERS_DIR="$AGENTS_DIR/handovers"

if [ ! -d "$AGENTS_DIR" ]; then
  exit 0  # Not an agent-initialized repo
fi

# Check if there's a recent handover (within last 10 minutes)
if [ -d "$HANDOVERS_DIR" ]; then
  latest=$(ls -t "$HANDOVERS_DIR"/*.md 2>/dev/null | head -1)
  if [ -n "$latest" ]; then
    # Get file modification time
    if [[ "$OSTYPE" == "darwin"* ]]; then
      file_time=$(stat -f %m "$latest" 2>/dev/null || echo 0)
    else
      file_time=$(stat -c %Y "$latest" 2>/dev/null || echo 0)
    fi
    now=$(date +%s)
    age=$(( now - file_time ))

    if [ $age -lt 600 ]; then
      # Recent handover exists, proceed
      exit 0
    fi
  fi
fi

# No recent handover — check if AGENTS.md was modified in this commit
if git diff --cached --name-only | grep -q "^AGENTS.md$"; then
  exit 0  # AGENTS.md is being updated, that counts
fi

# Warn but don't block
echo ""
echo "┌─────────────────────────────────────────────────────┐"
echo "│  agent: No recent handover found.                   │"
echo "│                                                     │"
echo "│  Consider running 'agent handover' to log your      │"
echo "│  progress so the next agent can pick up your work.  │"
echo "│                                                     │"
echo "│  This is a reminder, not a blocker.                 │"
echo "└─────────────────────────────────────────────────────┘"
echo ""

exit 0
HOOK
  chmod +x "$git_hooks_dir/pre-commit"

  # Post-commit hook — append commit info to latest handover
  cat > "$git_hooks_dir/post-commit" << 'HOOK'
#!/usr/bin/env bash
# Agent handoff post-commit hook
# Records commit hash in the latest handover

AGENTS_DIR=".agents"
HANDOVERS_DIR="$AGENTS_DIR/handovers"

if [ ! -d "$AGENTS_DIR" ]; then
  exit 0
fi

latest=$(ls -t "$HANDOVERS_DIR"/*.md 2>/dev/null | head -1)
if [ -n "$latest" ]; then
  hash=$(git rev-parse --short HEAD 2>/dev/null)
  msg=$(git log --oneline -1 2>/dev/null)
  echo "" >> "$latest"
  echo "## Commit" >> "$latest"
  echo "\`$msg\`" >> "$latest"
fi

exit 0
HOOK
  chmod +x "$git_hooks_dir/post-commit"
}

_update_agents_md_progress() {
  local summary="$1"
  local next_steps="$2"

  if [ ! -f "$AGENTS_MD" ]; then
    return 0
  fi

  local date_str
  date_str=$(iso_date)

  # Build the new progress entry
  local entry="- **$date_str** — $summary"

  # Check if the progress section has the placeholder
  if grep -q "^_No handovers yet._$" "$AGENTS_MD"; then
    # Replace the placeholder with the first entry
    if [[ "$OSTYPE" == "darwin"* ]]; then
      sed -i '' "s/^_No handovers yet._$/$entry/" "$AGENTS_MD"
    else
      sed -i "s/^_No handovers yet._$/$entry/" "$AGENTS_MD"
    fi
  else
    # Append after the "## Current Progress" section
    # Find the line number of "## Current Progress" and insert after the next non-empty line
    local line_num
    line_num=$(grep -n "^## Current Progress" "$AGENTS_MD" | head -1 | cut -d: -f1)
    if [ -n "$line_num" ]; then
      # Find the next content line after the section header and any comments
      local insert_after=$((line_num + 2))
      if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "${insert_after}i\\
${entry}
" "$AGENTS_MD"
      else
        sed -i "${insert_after}i\\${entry}" "$AGENTS_MD"
      fi
    fi
  fi

  # Update "What Needs to Be Done" if next_steps provided
  if [ -n "$next_steps" ] && [ "$next_steps" != "_No next steps logged._" ]; then
    local needs_line
    needs_line=$(grep -n "^## What Needs to Be Done" "$AGENTS_MD" | head -1 | cut -d: -f1 || true)
    if [ -n "$needs_line" ]; then
      local insert_at=$((needs_line + 4))
      local next_entry="- $next_steps"
      if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "${insert_at}i\\
${next_entry}
" "$AGENTS_MD"
      else
        sed -i "${insert_at}i\\${next_entry}" "$AGENTS_MD"
      fi
    fi
  fi

  return 0
}

