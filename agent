_agent_pointer_content() {
  cat << 'POINTER'
# Agent Instructions

Read the `AGENTS.md` file in this repository root for all project context,
architecture decisions, conventions, progress history, and handoff notes.

That file is the single source of truth maintained across all agent sessions.
Always read it at the start of a new session. Update it when you make
significant decisions or complete major work.

If running inside CMUX, use `cmux set-status`, `cmux log`, and `cmux notify`
to provide real-time progress visibility. See AGENTS.md for details.

For UI testing, use `agent test <url>` or `playwright-cli` directly.
See AGENTS.md for Playwright CLI commands.

If you notice workflow friction, log it with `agent recommend "suggestion"`.
POINTER
}

# Write a pointer file, merging with existing content if present.
# If the file already contains "Read the `AGENTS.md` file" it's ours — overwrite.
# If the file exists with other content, prepend pointer + append original under
# "## Previous Instructions".
# If the file doesn't exist, create it.
_write_pointer_file() {
  local filepath="$1"
  local pointer
  pointer=$(_agent_pointer_content)

  if [ -f "$filepath" ]; then
    local existing
    existing=$(cat "$filepath")

    if echo "$existing" | grep -q 'Read the `AGENTS.md` file'; then
      # Already a pointer from a previous init — overwrite
      echo "$pointer" > "$filepath"
    else
      # Existing non-pointer content — merge
      warn "Existing ${BOLD}${filepath}${RESET} found — merging with agent pointer"
      printf '%s\n\n---\n\n## Previous Instructions\n\n%s\n' "$pointer" "$existing" > "$filepath"
    fi
  else
    echo "$pointer" > "$filepath"
  fi
}

_create_agent_pointers() {
  # Every AI coding agent reads a different config file.
  # We create ALL of them, each pointing to AGENTS.md as the single source of truth.
  # This means you can switch between any agent tool and they all get the same context.

  # ── IDE agents ──────────────────────────────────────────
  # Cursor
  _write_pointer_file .cursorrules

  # Windsurf
  _write_pointer_file .windsurfrules

  # Cline (VS Code extension)
  _write_pointer_file .clinerules

  # GitHub Copilot
  mkdir -p .github
  _write_pointer_file .github/copilot-instructions.md

  # ── Terminal agents ─────────────────────────────────────
  # Claude Code
  _write_pointer_file CLAUDE.md

  # Cosine (cos2)
  mkdir -p .cosine
  _write_pointer_file .cosine/instructions.md

  # OpenCode
  mkdir -p .opencode
  _write_pointer_file .opencode/instructions.md

  # Codex (OpenAI)
  mkdir -p .codex
  _write_pointer_file .codex/instructions.md

  # Aider
  _write_pointer_file .aider.conf.yml

  # ── Generic ─────────────────────────────────────────────
  # Some agents look for these
  _write_pointer_file CONVENTIONS.md
}

_install_hooks() {
  local git_hooks_dir
  git_hooks_dir=$(git rev-parse --git-dir)/hooks

  # Pre-commit hook
  cat > "$git_hooks_dir/pre-commit" << 'HOOK'
#!/usr/bin/env bash
# Agent handoff pre-commit hook
# Reminds agents to create a handover entry before committing

AGENTS_DIR=".agents"
HANDOVERS_DIR="$AGENTS_DIR/handovers"

if [ ! -d "$AGENTS_DIR" ]; then
  exit 0  # Not an agent-initialized repo
fi

# Check if there's a recent handover (within last 10 minutes)
if [ -d "$HANDOVERS_DIR" ]; then
  latest=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | sort -r | head -1)
  if [ -n "$latest" ]; then
    # Get file modification time
    if [[ "$OSTYPE" == "darwin"* ]]; then
      file_time=$(stat -f %m "$latest" 2>/dev/null || echo 0)
    else
      file_time=$(stat -c %Y "$latest" 2>/dev/null || echo 0)
    fi
    now=$(date +%s)
    age=$(( now - file_time ))

    if [ $age -lt 600 ]; then
      # Recent handover exists, proceed
      exit 0
    fi
  fi
fi

# No recent handover — check if AGENTS.md was modified in this commit
if git diff --cached --name-only | grep -q "^AGENTS.md$"; then
  exit 0  # AGENTS.md is being updated, that counts
fi

# Warn but don't block
echo ""
echo "┌─────────────────────────────────────────────────────┐"
echo "│  agent: No recent handover found.                   │"
echo "│                                                     │"
echo "│  Consider running 'agent handover' to log your      │"
echo "│  progress so the next agent can pick up your work.  │"
echo "│                                                     │"
echo "│  This is a reminder, not a blocker.                 │"
echo "└─────────────────────────────────────────────────────┘"
echo ""

exit 0
HOOK
  chmod +x "$git_hooks_dir/pre-commit"

  # Post-commit hook — append commit info to latest handover
  cat > "$git_hooks_dir/post-commit" << 'HOOK'
#!/usr/bin/env bash
# Agent handoff post-commit hook
# Records commit hash in the latest handover

AGENTS_DIR=".agents"
HANDOVERS_DIR="$AGENTS_DIR/handovers"

if [ ! -d "$AGENTS_DIR" ]; then
  exit 0
fi

latest=$(find "$HANDOVERS_DIR" -maxdepth 1 -name "*.md" 2>/dev/null | sort -r | head -1)
if [ -n "$latest" ]; then
  hash=$(git rev-parse --short HEAD 2>/dev/null)
  msg=$(git log --oneline -1 2>/dev/null)
  echo "" >> "$latest"
  echo "## Commit" >> "$latest"
  echo "\`$msg\`" >> "$latest"
fi

# ── CMUX sidebar update on commit ──
if command -v cmux &>/dev/null; then
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  uncommitted=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
  msg=$(git log --oneline -1 2>/dev/null)
  cmux set-status "branch" "$branch" --icon "arrow.triangle.branch" --color "#81C784" 2>/dev/null || true
  cmux set-status "uncommitted" "$uncommitted files" --icon "pencil.circle.fill" --color "#FFB74D" 2>/dev/null || true
  cmux set-status "last-commit" "$msg" --icon "checkmark.seal.fill" --color "#81C784" 2>/dev/null || true
  cmux log --level success --source "git" -- "Committed: $msg" 2>/dev/null || true
fi

exit 0
HOOK
  chmod +x "$git_hooks_dir/post-commit"
}

_update_agents_md_progress() {
  local summary="$1"
  local learnings="$2"
  local next_steps="$3"

  if [ ! -f "$AGENTS_MD" ]; then
    return 0
  fi

  local date_str
  date_str=$(iso_date)

  # Build the new progress entry
  local entry="- **$date_str** — $summary"

  # Check if the progress section has the placeholder
  if grep -q "^_No handovers yet._$" "$AGENTS_MD"; then
    # Replace the placeholder with the first entry
    if [[ "$OSTYPE" == "darwin"* ]]; then
      sed -i '' "s/^_No handovers yet._$/$entry/" "$AGENTS_MD"
    else
      sed -i "s/^_No handovers yet._$/$entry/" "$AGENTS_MD"
    fi
  else
    # Append after the "## Current Progress" section
    # Find the line number of "## Current Progress" and insert after the next non-empty line
    local line_num
    line_num=$(grep -n "^## Current Progress" "$AGENTS_MD" | head -1 | cut -d: -f1)
    if [ -n "$line_num" ]; then
      # Find the next content line after the section header and any comments
      local insert_after=$((line_num + 2))
      if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "${insert_after}i\\
${entry}
" "$AGENTS_MD"
      else
        sed -i "${insert_after}i\\${entry}" "$AGENTS_MD"
      fi
    fi
  fi

  # Update "What Needs to Be Done" if next_steps provided
  if [ -n "$next_steps" ] && [ "$next_steps" != "_No next steps logged._" ]; then
    local needs_line
    needs_line=$(grep -n "^## What Needs to Be Done" "$AGENTS_MD" | head -1 | cut -d: -f1 || true)
    if [ -n "$needs_line" ]; then
      local insert_at=$((needs_line + 4))
      local next_entry="- $next_steps"
      if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "${insert_at}i\\
${next_entry}
" "$AGENTS_MD"
      else
        sed -i "${insert_at}i\\${next_entry}" "$AGENTS_MD"
      fi
    fi
  fi

  if [ -n "$learnings" ] && [ "$learnings" != "_No learnings or gotchas logged._" ]; then
    local decisions_line
    decisions_line=$(grep -n "^## Architecture & Key Decisions" "$AGENTS_MD" | head -1 | cut -d: -f1 || true)
    if [ -n "$decisions_line" ]; then
      local insert_at=$((decisions_line + 4))
      local learning_entry="- Learning / gotcha: $learnings"
      if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "${insert_at}i\\
${learning_entry}
" "$AGENTS_MD"
      else
        sed -i "${insert_at}i\\${learning_entry}" "$AGENTS_MD"
      fi
    fi
  fi

  return 0
}

