case "${1:-help}" in
  init)       shift; cmd_init "$@" ;;
  handover)   shift; cmd_handover "$@" ;;
  status)     shift; cmd_status "$@" ;;
  log)        shift; cmd_log "$@" ;;
  onboard)    shift; cmd_onboard "$@" ;;
  reinit)     shift; cmd_reinit "$@" ;;
  workspace|ws) shift; cmd_workspace "$@" ;;
  peek)         shift; cmd_peek "$@" ;;
  dashboard)    shift; cmd_dashboard "$@" ;;
  spawn)        shift; cmd_spawn "$@" ;;
  signal)       shift; cmd_signal "$@" ;;
  browse)       shift; cmd_browse "$@" ;;
  context|ctx)  shift; cmd_context "$@" ;;
  focus)        shift; cmd_focus "$@" ;;
  test)         shift; cmd_test "$@" ;;
  recommend|rec) shift; cmd_recommend "$@" ;;
  mcp)          shift; cmd_mcp "$@" ;;
  setup)        shift; cmd_setup "$@" ;;
  help|--help|-h) cmd_help ;;
  version|--version|-v) echo "agent $VERSION" ;;
  *) die "unknown command: $1. Run 'agent help' for usage." ;;
esac
