#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
AGENTS_DIR=".agents"
AGENTS_MD="AGENTS.md"
HANDOVERS_DIR="$AGENTS_DIR/handovers"
HOOKS_DIR="$AGENTS_DIR/hooks"
CONFIG_FILE="$AGENTS_DIR/config.yaml"

# ── Colors ────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────

die() { echo -e "${RED}error:${RESET} $1" >&2; exit 1; }
info() { echo -e "${BLUE}→${RESET} $1"; }
success() { echo -e "${GREEN}✓${RESET} $1"; }
warn() { echo -e "${YELLOW}!${RESET} $1"; }

require_git() {
  git rev-parse --git-dir &>/dev/null || die "not a git repository. Run 'git init' first."
}

require_init() {
  [ -d "$AGENTS_DIR" ] || die "agent not initialized. Run 'agent init' first."
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

timestamp() {
  date -u +"%Y-%m-%dT%H-%M-%S"
}

iso_date() {
  date -u +"%Y-%m-%d %H:%M UTC"
}

find_editor() {
  if [ -n "${VISUAL:-}" ]; then
    printf '%s\n' "$VISUAL"
    return 0
  fi

  if [ -n "${EDITOR:-}" ]; then
    printf '%s\n' "$EDITOR"
    return 0
  fi

  local editor
  for editor in nano vim vi; do
    if command -v "$editor" >/dev/null 2>&1; then
      printf '%s\n' "$editor"
      return 0
    fi
  done

  return 1
}

build_handover_summary_draft() {
  local branch="$1"
  local staged_count unstaged_count untracked_count total_count

  staged_count=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
  unstaged_count=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
  untracked_count=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
  total_count=$((staged_count + unstaged_count + untracked_count))

  if [ "$total_count" -gt 0 ] 2>/dev/null; then
    printf 'Updated %s file(s) on %s.' "$total_count" "$branch"
    return 0
  fi

  printf 'Wrapped up work on %s.' "$branch"
}

review_handover_draft() {
  local branch="$1"
  local last_commits="$2"
  local staged="$3"
  local unstaged="$4"
  local draft_summary="$5"
  local draft_decisions="$6"
  local draft_next_steps="$7"
  local choice editor draft_file input

  while true; do
    echo -e "${BOLD}Agent Handover${RESET} — $(iso_date)"
    echo ""
    echo -e "${DIM}Review the draft below. Edit it if needed, then accept to write the handover.${RESET}"
    echo ""
    echo -e "${BOLD}Draft Summary:${RESET} $draft_summary"
    echo -e "${BOLD}Draft Decisions:${RESET} $draft_decisions"
    echo -e "${BOLD}Draft Next Steps:${RESET} $draft_next_steps"
    echo ""
    echo -e "${DIM}Branch:${RESET} $branch"
    echo -e "${DIM}Recent commits:${RESET}"
    printf '%s\n' "$last_commits"
    echo ""
    echo -e "${DIM}Staged changes:${RESET}"
    printf '%s\n' "$staged"
    echo ""
    echo -e "${DIM}Unstaged changes:${RESET}"
    printf '%s\n' "$unstaged"
    echo ""
    printf 'Accept draft, edit draft, or cancel? [a/e/c]: '
    read -r choice

    case "$choice" in
      a|A|"")
        HANDOVER_SUMMARY="$draft_summary"
        HANDOVER_DECISIONS="$draft_decisions"
        HANDOVER_NEXT_STEPS="$draft_next_steps"
        return 0
        ;;
      e|E)
        if editor=$(find_editor); then
          draft_file=$(mktemp)
          cat > "$draft_file" << EOF
Summary: $draft_summary
Decisions: $draft_decisions
Next Steps: $draft_next_steps
EOF
          "$editor" "$draft_file"
          while IFS= read -r input; do
            case "$input" in
              Summary:*) draft_summary=${input#Summary: } ;;
              Decisions:*) draft_decisions=${input#Decisions: } ;;
              Next\ Steps:*) draft_next_steps=${input#Next Steps: } ;;
            esac
          done < "$draft_file"
          rm -f "$draft_file"
        else
          printf 'Summary [%s]: ' "$draft_summary"
          read -r input
          [ -n "$input" ] && draft_summary="$input"
          printf 'Decisions [%s]: ' "$draft_decisions"
          read -r input
          [ -n "$input" ] && draft_decisions="$input"
          printf 'Next Steps [%s]: ' "$draft_next_steps"
          read -r input
          [ -n "$input" ] && draft_next_steps="$input"
        fi
        echo ""
        ;;
      c|C)
        warn "handover cancelled"
        return 1
        ;;
      *)
        warn "enter 'a' to accept, 'e' to edit, or 'c' to cancel"
        echo ""
        ;;
    esac
  done
}

# ── Commands ──────────────────────────────────────────────

cmd_init() {
  require_git
  local root
  root=$(repo_root)
  cd "$root"

  if [ -d "$AGENTS_DIR" ]; then
    warn "already initialized at $root/$AGENTS_DIR"
    echo "  Run 'agent reinit' to regenerate config files."
    return 0
  fi

  local project_name
  project_name=$(basename "$root")

  info "Initializing agent handoff system in ${BOLD}$root${RESET}"

  # Create directory structure
  mkdir -p "$HANDOVERS_DIR" "$HOOKS_DIR"

  # Create config
  cat > "$CONFIG_FILE" << EOF
# Agent handoff configuration
project: $project_name
created: $(iso_date)

# Conventions for agents working on this repo
conventions:
  language: auto        # auto-detect from repo
  test_before_commit: true
  update_handover: true # remind agents to write handover before committing

# Agent-specific config file pointers (all point to AGENTS.md)
# These are auto-generated — edit AGENTS.md, not these files
agent_files:
  # IDE agents
  - .cursorrules              # Cursor
  - .windsurfrules            # Windsurf
  - .clinerules               # Cline
  - .github/copilot-instructions.md  # GitHub Copilot
  # Terminal agents
  - CLAUDE.md                 # Claude Code
  - .cosine/instructions.md   # Cosine (cos2)
  - .opencode/instructions.md # OpenCode
  - .codex/instructions.md    # Codex
  - .aider.conf.yml           # Aider
  # Generic
  - CONVENTIONS.md
EOF

  # Create AGENTS.md from template
  _generate_agents_md "$project_name"

  # Create agent config pointers
  _create_agent_pointers

  # Install git hooks
  _install_hooks

  # Create .gitignore additions
  if [ -f .gitignore ]; then
    if ! grep -q ".agents/handovers/" .gitignore 2>/dev/null; then
      echo "" >> .gitignore
      echo "# Agent handoff context dumps (can be large)" >> .gitignore
      echo "# Uncomment the next line to exclude handover logs from git" >> .gitignore
      echo "# .agents/handovers/" >> .gitignore
    fi
  fi

  echo ""
  success "Agent handoff system initialized"
  echo ""
  echo -e "  ${BOLD}What was created:${RESET}"
  echo -e "  ${DIM}AGENTS.md${RESET}              ← the source of truth (edit this)"
  echo -e "  ${DIM}.agents/${RESET}               ← handovers, config, hooks"
  echo ""
  echo -e "  ${BOLD}Agent pointers (all → AGENTS.md):${RESET}"
  echo -e "  ${DIM}.cursorrules${RESET}            Cursor"
  echo -e "  ${DIM}.windsurfrules${RESET}          Windsurf"
  echo -e "  ${DIM}.clinerules${RESET}             Cline"
  echo -e "  ${DIM}.github/copilot-*.md${RESET}    GitHub Copilot"
  echo -e "  ${DIM}CLAUDE.md${RESET}               Claude Code"
  echo -e "  ${DIM}.cosine/instructions${RESET}    Cosine (cos2)"
  echo -e "  ${DIM}.opencode/instructions${RESET}  OpenCode"
  echo -e "  ${DIM}.codex/instructions${RESET}     Codex"
  echo -e "  ${DIM}.aider.conf.yml${RESET}         Aider"
  echo ""
  echo -e "  ${BOLD}Next steps:${RESET}"
  echo -e "  1. Edit ${BOLD}AGENTS.md${RESET} with your project context"
  echo -e "  2. Start working with ${BOLD}any${RESET} agent tool — they all read AGENTS.md"
  echo -e "  3. Run ${BOLD}agent handover${RESET} before switching to a different agent"
}

cmd_handover() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local ts
  ts=$(timestamp)
  local handover_file="$HANDOVERS_DIR/$ts.md"

  # Gather context
  local branch
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local last_commits
  last_commits=$(git log --oneline -5 2>/dev/null || echo "no commits yet")
  local staged
  staged=$(git diff --cached --stat 2>/dev/null || echo "nothing staged")
  local unstaged
  unstaged=$(git diff --stat 2>/dev/null || echo "nothing unstaged")
  local untracked
  untracked=$(git ls-files --others --exclude-standard 2>/dev/null)

  if [ -n "$untracked" ]; then
    unstaged=$(printf '%s\n\nUntracked files:\n%s' "$unstaged" "$untracked")
  fi

  # Check for arguments (non-interactive mode for agents)
  local summary=""
  local decisions=""
  local next_steps=""
  local context=""
  local summary_draft=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --summary|-s) summary="$2"; shift 2 ;;
      --decisions|-d) decisions="$2"; shift 2 ;;
      --next|-n) next_steps="$2"; shift 2 ;;
      --context|-c) context="$2"; shift 2 ;;
      --stdin) context=$(cat); shift ;;
      *) die "unknown option: $1" ;;
    esac
  done

  # If no args, check if stdin has data (piped context)
  if [ -z "$summary" ] && [ -z "$context" ] && [ ! -t 0 ]; then
    context=$(cat)
    summary="Automated handover"
  fi

  # If still no args and interactive terminal, prompt
  if [ -z "$summary" ] && [ -t 0 ]; then
    summary_draft=$(build_handover_summary_draft "$branch")
    decisions="_No decisions logged._"
    next_steps="_No next steps logged._"

    review_handover_draft "$branch" "$last_commits" "$staged" "$unstaged" "$summary_draft" "$decisions" "$next_steps" || return 1
    summary="$HANDOVER_SUMMARY"
    decisions="$HANDOVER_DECISIONS"
    next_steps="$HANDOVER_NEXT_STEPS"
  fi

  [ -z "$summary" ] && summary="Work session $(iso_date)"

  # Write handover file
  cat > "$handover_file" << EOF
# Handover — $(iso_date)

## Summary
$summary

## Key Decisions
${decisions:-_No decisions logged._}

## Next Steps
${next_steps:-_No next steps logged._}

## Git State
- **Branch:** $branch
- **Recent commits:**
\`\`\`
$last_commits
\`\`\`
- **Staged changes:**
\`\`\`
$staged
\`\`\`
- **Unstaged changes:**
\`\`\`
$unstaged
\`\`\`
EOF

  # Append context dump if provided
  if [ -n "$context" ]; then
    cat >> "$handover_file" << EOF

## Conversation Context
<details>
<summary>Full context from agent session (click to expand)</summary>

$context

</details>
EOF
  fi

  # Update AGENTS.md with latest handover summary
  _update_agents_md_progress "$summary" "$next_steps"

  success "Handover saved to $handover_file"
  echo ""
  echo -e "  ${DIM}Summary:${RESET} $summary"
  if [ -n "$decisions" ] && [ "$decisions" != "_No decisions logged._" ]; then echo -e "  ${DIM}Decisions:${RESET} $decisions"; fi
  if [ -n "$next_steps" ] && [ "$next_steps" != "_No next steps logged._" ]; then echo -e "  ${DIM}Next steps:${RESET} $next_steps"; fi
  if [ -n "$context" ]; then echo -e "  ${DIM}Context:${RESET} $(echo "$context" | wc -c | tr -d ' ') bytes captured"; fi
}

cmd_status() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local project_name
  project_name=$(basename "$root")

  echo -e "${BOLD}Agent Status — $project_name${RESET}"
  echo ""

  # Last handover
  local latest
  latest=$(ls -t "$HANDOVERS_DIR"/*.md 2>/dev/null | head -1)
  if [ -n "$latest" ]; then
    local handover_name
    handover_name=$(basename "$latest" .md)
    local handover_summary
    handover_summary=$(sed -n '/^## Summary$/,/^##/{/^## Summary$/d;/^##/d;p;}' "$latest" | head -3 | sed 's/^[[:space:]]*//')
    echo -e "  ${BOLD}Last handover:${RESET} $handover_name"
    echo -e "  ${DIM}$handover_summary${RESET}"
  else
    echo -e "  ${BOLD}Last handover:${RESET} ${DIM}none${RESET}"
  fi
  echo ""

  # Handover count
  local count
  count=$(ls "$HANDOVERS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  ${BOLD}Total handovers:${RESET} $count"

  # Git state
  local branch
  branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local uncommitted
  uncommitted=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
  echo -e "  ${BOLD}Branch:${RESET} $branch"
  echo -e "  ${BOLD}Uncommitted changes:${RESET} $uncommitted files"

  # AGENTS.md exists and has content
  if [ -f "$AGENTS_MD" ]; then
    local lines
    lines=$(wc -l < "$AGENTS_MD" | tr -d ' ')
    echo -e "  ${BOLD}AGENTS.md:${RESET} $lines lines"
  else
    echo -e "  ${BOLD}AGENTS.md:${RESET} ${RED}missing${RESET}"
  fi
  echo ""
}

cmd_log() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local handovers
  handovers=$(ls -t "$HANDOVERS_DIR"/*.md 2>/dev/null)

  if [ -z "$handovers" ]; then
    echo -e "${DIM}No handovers yet. Run 'agent handover' to create one.${RESET}"
    return 0
  fi

  echo -e "${BOLD}Handover Log${RESET}"
  echo ""

  local limit=${1:-10}
  local i=0

  for file in $handovers; do
    [ $i -ge "$limit" ] && break
    local name
    name=$(basename "$file" .md)
    local summary
    summary=$(sed -n '/^## Summary$/,/^##/{/^## Summary$/d;/^##/d;p;}' "$file" | head -1 | sed 's/^[[:space:]]*//')
    echo -e "  ${YELLOW}$name${RESET}  $summary"
    i=$((i + 1))
  done

  local total
  total=$(ls "$HANDOVERS_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
  if [ "$total" -gt "$limit" ] 2>/dev/null; then
    echo -e "\n  ${DIM}... and $((total - limit)) more${RESET}"
  fi
}

cmd_onboard() {
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  local name="${1:-}"
  local config_path="${2:-}"

  if [ -z "$name" ]; then
    echo -e "${BOLD}Onboard a new agent tool${RESET}"
    echo ""
    echo -e "${DIM}Agent tool name (e.g. 'devin', 'bolt', 'replit-agent'):${RESET}"
    read -r name
    [ -z "$name" ] && die "agent name is required"
    echo ""
    echo -e "${DIM}Config file path this agent reads (e.g. '.devin/instructions.md', 'DEVIN.md'):${RESET}"
    echo -e "${DIM}Leave empty to create ${name}.md in the repo root${RESET}"
    read -r config_path
  fi

  # Default config path: {name}.md in repo root, or .{name}/instructions.md if name is lowercase
  if [ -z "$config_path" ]; then
    local lower
    lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
    config_path=".${lower}/instructions.md"
  fi

  # Create the pointer file
  local pointer
  pointer=$(cat << 'POINTER'
# Agent Instructions

Read the `AGENTS.md` file in this repository root for all project context,
architecture decisions, conventions, progress history, and handoff notes.

That file is the single source of truth maintained across all agent sessions.
Always read it at the start of a new session. Update it when you make
significant decisions or complete major work.
POINTER
)

  local dir
  dir=$(dirname "$config_path")
  if [ "$dir" != "." ]; then
    mkdir -p "$dir"
  fi
  echo "$pointer" > "$config_path"

  # Register in config
  echo "  - $config_path    # $name" >> "$CONFIG_FILE"

  success "Onboarded ${BOLD}$name${RESET}"
  echo ""
  echo -e "  ${DIM}Created:${RESET} $config_path → points to AGENTS.md"
  echo -e "  ${DIM}Registered in:${RESET} $CONFIG_FILE"
  echo ""
  echo -e "  $name will now read AGENTS.md when it opens this repo."
}

cmd_reinit() {
  require_git
  require_init
  local root
  root=$(repo_root)
  cd "$root"

  info "Regenerating agent config files"
  _create_agent_pointers
  _install_hooks
  success "Agent config files regenerated"
}

cmd_help() {
  cat << 'EOF'

  agent — git for agents

  Structured handoff system so any AI coding agent can pick up
  where the last one left off. Start with Cursor, continue with
  Claude Code, finish with Cosine — no context lost.

  Works with: Cursor, Windsurf, Cline, GitHub Copilot, Claude Code,
  Cosine (cos2), OpenCode, Codex, Aider, and any future agent tool.

  COMMANDS

    agent init                    Initialize agent handoff in a git repo
    agent handover                Log progress, decisions, and context
    agent status                  Show current agent state
    agent log [n]                 Show recent handover entries
    agent onboard <name> [path]   Register a new/unknown agent tool
    agent reinit                  Regenerate config files and hooks

  HANDOVER OPTIONS

    agent handover --summary "what was done"     -s for short
    agent handover --decisions "key choices"      -d for short
    agent handover --next "what to do next"       -n for short
    agent handover --context "conversation dump"  -c for short
    agent handover --stdin                        read context from stdin

  EXAMPLES

    # Initialize a repo
    cd my-project && agent init

    # Log a handover before switching agents
    agent handover -s "Built auth with NextAuth" -d "Chose JWT over sessions" -n "Add protected routes"

    # Interactive mode: review, edit, and accept the drafted handover
    agent handover

    # Pipe conversation context from an agent session
    cat conversation.txt | agent handover -s "Debugging session"

    # Check current state
    agent status

    # New agent tool? Onboard it
    agent onboard devin .devin/instructions.md
    agent onboard bolt                           # auto-creates .bolt/instructions.md

  HOW IT WORKS

    agent init creates AGENTS.md as the single source of truth,
    plus pointer files for every agent tool (.cursorrules, CLAUDE.md,
    .cosine/instructions.md, etc.) that all say "read AGENTS.md".

    When you switch agents, run agent handover. It drafts a handover
    from the current repo state, then lets a human review, edit, and
    accept it before writing the log. The next agent reads AGENTS.md
    and the handover log to pick up seamlessly.

    A pre-commit hook gently reminds you to handover before committing.

EOF
}

